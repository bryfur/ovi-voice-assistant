# ---- Devices ----
# Comma-separated: host[:port[:encryption_key]]
# Examples:
#   OVA_DEVICES=voice-pe.local
#   OVA_DEVICES=voice-pe-1.local,voice-pe-2.local
#   OVA_DEVICES=voice-pe.local::encryption_key_here
#   OVA_DEVICES=192.168.1.100:6053:encryption_key_here
# OVA_DEVICES=voice-pe-097502.local::encryption_key_here

# ---- Agent (LLM) ----
# OVA_OPENAI_BASE_URL=https://api.openai.com/v1
# OVA_OPENAI_API_KEY=
# OVA_AGENT_MODEL=gpt-4o-mini
# OVA_AGENT_INSTRUCTIONS=You are a voice assistant...

# ---- STT ----
# OVA_STT_PROVIDER=whisper
# OVA_STT_MODEL=base.en
# OVA_STT_LANGUAGE=en
# OVA_STT_BEAM_SIZE=1
# OVA_STT_COMPUTE_TYPE=int8

# ---- TTS ----
# OVA_TTS_PROVIDER=piper
# OVA_TTS_MODEL=en_US-lessac-medium
# OVA_TTS_SPEAKER_ID=
# OVA_TTS_LENGTH_SCALE=1.0
# OVA_TTS_SENTENCE_SILENCE=0.1

# ---- Audio (advanced, match Voice PE hardware) ----
# OVA_SAMPLE_RATE=16000
# OVA_SAMPLE_WIDTH=2
# OVA_CHANNELS=1
